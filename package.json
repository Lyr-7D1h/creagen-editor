{
  "name": "creagen-editor",
  "version": "0.0.1",
  "description": "",
  "scripts": {
    "start": "vite -m dev",
    "start:prod": "vite -m production",
    "build": "vite build -m production",
    "build:sandbox": "VITE_ENTRYPOINT=sandbox vite build -m production && mv dist/sandbox-runtime/index.html dist/index.html && rm -r dist/sandbox-runtime",
    "format": "prettier -w src/",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "generate-types:remote": "openapi-typescript ${CREAGEN_REMOTE_URL:-https://storage.creagen.dev}/openapi.json -o src/remote/storage.d.ts"
  },
  "keywords": [
    "creative coding",
    "editor",
    "web"
  ],
  "author": "Lyr",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-glob": "^3.3.3",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.13.0",
    "prettier": "3.8.1",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@msgpack/msgpack": "^3.1.3",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^9.0.0",
    "@types/d3": "^7.4.3",
    "allotment": "^1.20.5",
    "d3": "^7.9.0",
    "lz-string": "^1.5.0",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-qr-code": "^2.0.18",
    "react-rnd": "^10.5.3",
    "semver": "^7.7.4",
    "typescript": "^6.0.2",
    "typescript-result": "^3.5.2",
    "versie": "^1.1.4",
    "zod": "^4.3.6"
  }
}
